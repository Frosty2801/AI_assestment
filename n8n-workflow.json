      ]
    },
    {
      "parameters": {
        "content": "Si `escalate=true` o falla la API, notifica a humano por Slack webhook y devuelve una respuesta de escalamiento.",
        "height": 220,
        "width": 360
      },
      "id": "13",
      "name": "Note Escalation",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
